# Application
APP_NAME="PropPilot AI"
APP_VERSION="1.0.0"
DEBUG=true
ENVIRONMENT=development

# API
API_V1_PREFIX="/api/v1"
HOST=0.0.0.0
PORT=8000

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/proppilot
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-key

# Supabase Auth
SUPABASE_JWT_SECRET=your-jwt-secret

# JWT
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Google AI (Gemini)
GOOGLE_API_KEY=your-google-api-key
GEMINI_MODEL=gemini-1.5-pro
GEMINI_TEMPERATURE=0.7

# LangGraph
LANGGRAPH_CHECKPOINT_TYPE=memory

# Redis (for caching/sessions)
REDIS_URL=redis://localhost:6379/0

# Email (SendGrid/Resend)
SENDGRID_API_KEY=your-sendgrid-key
SENDGRID_FROM_EMAIL=noreply@proppilot.ai
FROM_EMAIL=noreply@proppilot.ai

# SMS (Twilio)
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-token
TWILIO_PHONE_NUMBER=+15551234567

# WhatsApp (Twilio/WhatsApp Business API)
WHATSAPP_PHONE_NUMBER_ID=your-whatsapp-id
WHATSAPP_ACCESS_TOKEN=your-whatsapp-token
WHATSAPP_VERIFY_TOKEN=your-verify-token

# Frontend
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# Celery/Redis for background tasks
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Monitoring
SENTRY_DSN=
PROMETHEUS_ENABLED=false

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_DIR=./uploads